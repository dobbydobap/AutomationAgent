# ─────────────────────────────────────────────────────────────────────────────
#  STREET ID // AUTOMATION AGENT  —  configuration template
#  Copy this file to ".env" and adjust as needed:   cp .env.example .env
#  Nothing here is secret by default; ANTHROPIC_API_KEY is only needed if you
#  switch the agent brain to the optional LLM mode.
# ─────────────────────────────────────────────────────────────────────────────

# ── Target task ──────────────────────────────────────────────────────────────
# The page the agent navigates to and fills in.
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Values the agent types into the two fields.
# NAME_VALUE goes into the first text field (labelled "Bug Title" / "Name").
# DESCRIPTION_VALUE goes into the multi-line "Description" textarea.
NAME_VALUE=STREET ID STUDIO
DESCRIPTION_VALUE=Autonomous form fill performed by the STREET ID automation agent using Playwright. Don't copy — create.

# ── Browser behaviour ────────────────────────────────────────────────────────
# HEADLESS=false shows a real Chromium window (best for the live viva demo).
# HEADLESS=true runs invisibly (useful on a server / CI).
HEADLESS=false

# Slow every Playwright action down by N milliseconds so a human can follow the
# demo. Set to 0 for full speed.
SLOW_MO=350

# Hard navigation/element timeout in milliseconds.
TIMEOUT_MS=30000

# ── Generic "navigate + search" task (CLI/dashboard defaults) ────────────────
# Used by:  python main.py --search "iphone 15 pro"
# and to pre-fill the dashboard's search inputs.
SEARCH_URL=https://duckduckgo.com
SEARCH_QUERY=iphone 15 pro

# Max actions the optional LLM free-form task loop will take before stopping.
MAX_TASK_STEPS=8

# ── Agent brain (hybrid) ─────────────────────────────────────────────────────
# false -> deterministic heuristic/search (no key, no network, never fails live).
# true  -> use an LLM for the free-form task loop and the optional form planner.
#          Works with ANY OpenAI-compatible provider; defaults target Groq (FREE).
USE_LLM=false

# Free options (pick one), get a key, paste it below:
#   Groq (recommended, free):  https://console.groq.com/keys
#     LLM_BASE_URL=https://api.groq.com/openai/v1     LLM_MODEL=llama-3.3-70b-versatile
#   OpenRouter (free models):  https://openrouter.ai/keys
#     LLM_BASE_URL=https://openrouter.ai/api/v1       LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Google Gemini (free):      https://aistudio.google.com/apikey
#     LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/   LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# ── Output locations ─────────────────────────────────────────────────────────
SCREENSHOT_DIR=screenshots
LOG_DIR=logs

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
